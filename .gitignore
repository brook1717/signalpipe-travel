# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.env.bak
.python-version

# Type-checker / linter caches
.mypy_cache/
.dmypy.json
.ruff_cache/
.pytype/

# ============================================================
# Secrets & Credentials  ← NEVER commit these
# ============================================================
.env
.env.*
!.env.example          # keep the template, never the filled copy

# AWS credentials
.aws/
credentials
*.pem
*.key
*.p12
*.pfx

# Google / Gemini API keys
service_account*.json
*-credentials.json

# ============================================================
# Testing
# ============================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
test-results/
junit*.xml

# ============================================================
# Terraform
# ============================================================
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/*.tfstate.*.backup
terraform/tfplan
terraform/override.tf
terraform/override.tf.json
terraform/*_override.tf
terraform/*_override.tf.json

# ============================================================
# Docker
# ============================================================
.dockerignore.bak

# ============================================================
# Output files generated by the scraper
# ============================================================
output/*.csv
output/*.json
output/*.xlsx
*.csv
*.xlsx
# Keep output/ directory in git but not its contents
!output/.gitkeep

# ============================================================
# Logs
# ============================================================
*.log
logs/
*.log.*

# ============================================================
# IDE & Editor
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
*.sublime-workspace
*.sublime-project

# ============================================================
# OS artifacts
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================================
# Playwright / browser testing
# ============================================================
playwright-report/
test-results/
.playwright/

# ============================================================
# Streamlit
# ============================================================
.streamlit/secrets.toml

# ============================================================
# Jupyter (if ever used)
# ============================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# ============================================================
# Alembic migration temp files
# ============================================================
alembic/versions/__pycache__/
